# FixMyNight Backend — Environment Variables
# Copy to .env for local development. NEVER commit .env to git.
# In production, set these in Railway dashboard → Service → Variables.

# Database — auto-set by Railway PostgreSQL plugin in production
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/fixmynight

# Vapi
VAPI_API_KEY=your_vapi_api_key
VAPI_WEBHOOK_SECRET=generate_with_openssl_rand_hex_32

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_DEFAULT_NUMBER=+15551234567

# Auth
JWT_SECRET=generate_with_openssl_rand_hex_64
JWT_ALGORITHM=HS256
ADMIN_PASSWORD_HASH=generate_with_passlib_bcrypt

# Admin alerts
ADMIN_PHONE=+15551234567

# Email
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=hello@fixmyday.ai

# Environment
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
